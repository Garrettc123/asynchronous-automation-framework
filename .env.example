# Flask Configuration
FLASK_APP=phase1.src.api.app
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DATABASE_URL=postgresql://automation_user:secure_password@localhost:5432/automation_db

# Stripe Configuration
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Affiliate Configuration
AFFILIATE_COMMISSION_RATE=0.20
AFFILIATE_COOKIE_DURATION=30

# Services Marketplace Configuration
MARKETPLACE_FEE_PERCENTAGE=0.15

# Content Monetization Configuration
CONTENT_ACCESS_DURATION=365
SUBSCRIPTION_PLANS=basic,premium,enterprise

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/0
